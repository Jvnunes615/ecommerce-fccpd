# Chave secreta usada para assinar e validar os tokens JWT.
# DEVE ser a mesma em todos os servicos.
JWT_SECRET=troque-esta-chave-secreta-em-producao
JWT_EXPIRES_SECONDS=3600

# Portas dos servicos
USERS_PORT=5001
PRODUCTS_PORT=5002
PRODUCTS_REPLICA_PORT=5012
ORDERS_PORT=5003
GATEWAY_PORT=8080

# URLs internas (Gateway e replicacao). Local: localhost; docker-compose: nome do servico.
USERS_URL=https://localhost:5001
PRODUCTS_URL=https://localhost:5002
PRODUCTS_REPLICA_URL=https://localhost:5012
ORDERS_URL=https://localhost:5003

# Heartbeat
HEARTBEAT_INTERVAL_MS=5000
HEARTBEAT_MAX_FAILURES=2

# TLS/HTTPS interno (gerado por scripts/generate_certs.py). Defina como
# "false" para rodar tudo em HTTP simples (sem certificados).
USE_TLS=true
